# --- Required ---
TELEGRAM_BOT_TOKEN=        # Get from @BotFather on Telegram
OPENAI_API_KEY=            # https://platform.openai.com/api-keys

# --- Optional: which MCP server to attach ---
# Defaults below give the bot filesystem access under /tmp.
# Examples of other MCP servers (require Node.js / npx):
#   Brave Search:   MCP_ARGS=-y @modelcontextprotocol/server-brave-search
#   GitHub:         MCP_ARGS=-y @modelcontextprotocol/server-github
#   Postgres:       MCP_ARGS=-y @modelcontextprotocol/server-postgres "postgres://..."
#   Slack:          MCP_ARGS=-y @modelcontextprotocol/server-slack
MCP_COMMAND=npx
MCP_ARGS=-y @modelcontextprotocol/server-filesystem /tmp
